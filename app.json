{
  "expo": {
    "name": "Meu Controle",
    "owner": "andersonbrodrigues",
    "slug": "meucontrole",
    "description": "Aplicativo para acompanhamento pessoal de pressão, glicose, peso e lembretes de medicamentos. Não substitui orientação, diagnóstico ou acompanhamento profissional.",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/logo_azul.png",
    "scheme": "meucontrole",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.andersonrodrigues.meucontrole",
      "buildNumber": "1",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Permitir que o Meu Controle use biometria para desbloquear o aplicativo com segurança."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#061B3A",
        "foregroundImage": "./assets/images/logo_azul.png",
        "monochromeImage": "./assets/images/logo_branco.png"
      },
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "package": "com.andersonrodrigues.meucontrole"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logo_azul.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir que o Meu Controle acesse sua galeria para escolher a foto de perfil.",
          "cameraPermission": "Permitir que o Meu Controle use a camera para tirar sua foto de perfil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo_branco.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#061B3A",
          "dark": {
            "image": "./assets/images/logo_branco.png",
            "backgroundColor": "#061B3A"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-secure-store",
      "expo-sharing",
      "expo-sqlite",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiBaseUrl": "https://controle.sigmaos.com.br/api/v1",
      "router": {},
      "eas": {
        "projectId": "831f0b4f-4d98-4481-a785-0555e2136ed1"
      }
    }
  }
}
